# Copy to .env and fill values. NEVER commit your real private key.
PRIVATE_KEY="YOUR_PRIVATE_KEY"
BASE_RPC_PUBLIC="https://mainnet.base.org" # public RPC (fallback)
BASE_RPC_PRIVATE="https://your-private-base-rpc.example" # private RPC for MEV/private txs
FLASHLOAN_AMOUNT="1000000000000000000" # amount in wei (example 1 ETH)
TOKEN_A="0x..." # ERC20 token A address
TOKEN_B="0x..." # ERC20 token B address
TOKEN_C="0x..." # Optional token C for triangular arbitrage
CONTRACT_ADDRESS="0x..." # deployed FlashloanReceiver contract
MIN_PROFIT_WEI="1000000000000000" # minimum profit in wei to execute (e.g., 0.001 ETH)
GAS_LIMIT="1000000"
MAX_GAS_PRICE_GWEI="200"
FLASHBOTS_RELAY="https://relay.flashbots.net"
SUSHISWAP_ROUTER="0x..." # Sushiswap router address
AERODROME_ROUTER="0x..." # Aerodrome router address
UNISWAP_V3_QUOTER="0x..." # Uniswap V3 quoter (optional)

